# ---------------------------------------------------------------------------
# Production environment for docker-compose.coolify.yml
#
# In Coolify: paste these into the compose resource's "Environment Variables"
# (mark the secrets as such). Do NOT commit a filled-in copy of this file.
# Generate secrets with:  openssl rand -hex 32
# ---------------------------------------------------------------------------

# --- Core ---
NODE_ENV=production
LOG_LEVEL=info
# Public origin of the SPA; used for the gateway CORS allow-list.
CORS_ORIGIN=https://improveit.today

# --- Postgres (PostGIS) ---
POSTGRES_USER=improveit
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=improveit

# --- Redis (rate-limit store, shared across gateway replicas) ---
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- Auth / JWT ---
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# --- Rate limiting (gateway) ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# --- Kafka ---
KAFKA_CLIENT_ID=improveit-today

# --- Voting ---
VOTE_AGG_REFRESH_MS=5000

# --- Geolocation ---
NOMINATIM_URL=https://nominatim.openstreetmap.org

# --- Payments ---
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_live_CHANGE_ME

# --- Notifications (email + SMS) ---
SENDGRID_API_KEY=SG.CHANGE_ME
SENDGRID_FROM_EMAIL=noreply@improveit.today
SENDGRID_FROM_NAME=ImproveIt.Today
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+10000000000

# --- Object storage (MinIO). These creds are BOTH the MinIO root user and the
#     media-service S3 client, so they must match. ---
S3_BUCKET=improveit
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME_minio_access_key
S3_SECRET_KEY=CHANGE_ME_minio_secret_key
# Public base URL for serving uploaded media. Until you expose a storage/CDN
# host, internal-only is fine; media links just won't resolve from the browser.
CDN_URL=http://minio:9000

# --- Search (Elasticsearch, internal) ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- Web app build-time (Vite inlines this into the bundle) ---
VITE_MAPBOX_TOKEN=pk.CHANGE_ME_mapbox_public_token

# --- Telegram bot (optional; comment the service out if unused) ---
TELEGRAM_BOT_TOKEN=CHANGE_ME_bot_token

{
  "name": "improveit-today",
  "version": "0.1.0",
  "description": "Global open-source service desk platform",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "interfaces/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api-gateway": "turbo run dev --filter=api-gateway",
    "dev:user-service": "turbo run dev --filter=user-service",
    "dev:problem-service": "turbo run dev --filter=problem-service",
    "dev:telegram-bot": "turbo run dev --filter=telegram-bot",
    "dev:web-app": "turbo run dev --filter=web-app",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "node packages/database/scripts/migrate.js",
    "db:seed": "node packages/database/scripts/seed.js",
    "db:rollback": "node packages/database/scripts/rollback.js"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}

# API Gateway
API_GATEWAY_PORT=8000
API_GATEWAY_HOST=0.0.0.0
JWT_SECRET=change-me-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=improveit
POSTGRES_PASSWORD=dev-password
POSTGRES_DB=improveit_dev
DATABASE_URL=postgresql://improveit:dev-password@localhost:5432/improveit_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=improveit-today

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=improveit

# Service URLs (Internal)
USER_SERVICE_URL=http://localhost:8001
PROBLEM_SERVICE_URL=http://localhost:8002
VOTING_SERVICE_URL=http://localhost:8003
GEOLOCATION_SERVICE_URL=http://localhost:8004
AUTHORITY_SERVICE_URL=http://localhost:8005
PAYMENT_SERVICE_URL=http://localhost:8006
BIDDING_SERVICE_URL=http://localhost:8007
NOTIFICATION_SERVICE_URL=http://localhost:8008
SEARCH_SERVICE_URL=http://localhost:8009
MEDIA_SERVICE_URL=http://localhost:8010
ANALYTICS_SERVICE_URL=http://localhost:8011
MODERATION_SERVICE_URL=http://localhost:8012

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# External APIs
MAPBOX_API_KEY=your-mapbox-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-key
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Payment
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@improveit.today
SENDGRID_FROM_NAME=ImproveIt.Today

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Storage (S3/MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=improveit-dev
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
CDN_URL=http://localhost:9000

# Application
NODE_ENV=development
LOG_LEVEL=debug
PORT=8000
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
# Stricter limit for /api/auth/{login,register,refresh} (brute-force guard)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
